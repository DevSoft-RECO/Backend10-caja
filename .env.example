APP_NAME=base
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8002

# Redireccionamiento y Sincronía del Ecosistema SSO (Madre/Hija)
APP_MADRE_URL=http://localhost:8000
APP_URL_FRONTEND=http://localhost:5190

# Categoría de permisos asignada a esta aplicación hija en el SSO central
# (Solo se sincronizarán localmente los permisos que pertenezcan a esta categoría)
SSO_PERMISSION_CATEGORY="App_Hija"

# Base de datos local (Por defecto SQLite para facilidad, descomenta MySQL si lo usas)
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Configuración de sesiones y cookies (SESSION_DOMAIN=null previene colisiones)
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=null

# Conexión de cola: 'sync' procesa las notificaciones y tareas de inmediato en tiempo real
# sin guardarlas en la base de datos (evita acumular jobs y retrasar las notificaciones).
QUEUE_CONNECTION=sync

# Configuraciones por defecto básicas de Laravel
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
CACHE_STORE=file
LOG_CHANNEL=stack
LOG_LEVEL=debug

# === BACKUP SYSTEM ===
BACKUP_MADRE_TOKEN=secreto_backup_hija_app2_2026
BACKUP_MYSQLDUMP_PATH=mysqldump
